# ═══════════════════════════════════════════════════════════════
# Kora — variáveis de ambiente
# ═══════════════════════════════════════════════════════════════
# Copie pra .env.local em dev, ou configure na UI do Easypanel em prod.
# Linhas marcadas [BUILD] precisam estar disponíveis no momento do
# `next build` (passar como Build Arg no Easypanel).
# Linhas marcadas [RUNTIME] só precisam no runtime (Environment).

# ── Supabase ─────────────────────────────────────────────────────
# [BUILD] — vão no bundle do client (NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [RUNTIME] — service_role NUNCA exposto no client
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── NextAuth v5 ──────────────────────────────────────────────────
# [RUNTIME]
# AUTH_SECRET: gere com `openssl rand -base64 32`
AUTH_SECRET=
# AUTH_URL: URL pública (https) onde o Kora roda
AUTH_URL=https://kora.seudominio.com.br
NEXTAUTH_URL=https://kora.seudominio.com.br

# ── Cifragem de segredos em repouso (docs/security.md §5) ────────
# [RUNTIME — servidor, NÃO é NEXT_PUBLIC]
# Cifra tokens Meta/Evolution no banco (AES-256-GCM). 32 bytes base64.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠️ GUARDAR num gerenciador de senhas — perder a chave = perder o dado cifrado.
# Sem ela, a cifragem fica DESLIGADA (no-op) — nada quebra.
ENCRYPTION_KEY=

# ── Evolution API global (auto-provisionamento) ──────────────────
# [RUNTIME] — só super-admin enxerga
EVOLUTION_API_URL=https://sua-evolution-api.exemplo.com
EVOLUTION_API_KEY=
# Domínio público onde Kora roda — Evolution chama webhooks aqui
WEBHOOK_BASE_URL=https://kora.seudominio.com.br
# false desliga auto-provision (útil em staging)
AUTO_PROVISION_ON_TENANT_CREATE=true

# ── OpenAI (Atendente IA) ────────────────────────────────────────
# [RUNTIME]
OPENAI_API_KEY=

# ── Resend (envio de convites por email) ─────────────────────────
# [RUNTIME] — opcional. Se vazio, envio por email fica desabilitado na UI.
# Conta em resend.com → domínio verificado → API key.
RESEND_API_KEY=
# Formato: "Kora <noreply@kora.seudominio.com.br>". Domínio precisa estar
# verificado no Resend (SPF + DKIM apontando pros DNS deles).
EMAIL_FROM=

# ── Crons (tarefas agendadas) ────────────────────────────────────
# [RUNTIME] — protege os endpoints /api/cron/* (ping-evolution, daily-reports,
# billing). O scheduler externo manda no header: Authorization: Bearer <valor>.
# Gere com `openssl rand -base64 32`. SE FICAR VAZIO, os endpoints ficam ABERTOS
# (qualquer um pode disparar) — sempre setar em produção.
# ⚠️ Os crons rodam no Supabase via pg_cron + pg_net (net.http_get nos /api/cron/*).
#    Este valor precisa BATER com o Bearer embutido nos jobs do pg_cron.
#    Ver DEPLOY.md §7 "Crons".
CRON_SECRET=

# ── WhatsApp Cloud API oficial (Meta) ────────────────────────────
# [RUNTIME] — só pra instâncias provider='meta_cloud'. Doc: docs/whatsapp-cloud-api.md.
# Credenciais POR número (token/phone_number_id/waba) ficam em whatsapp_instances,
# NÃO aqui. Estas são as globais do app:
#
# META_VERIFY_TOKEN: string que o webhook GET compara com hub.verify_token.
#   Precisa BATER com o "Token de verificação" configurado no painel Meta
#   (App → WhatsApp → Configuração → Webhook). Gere uma string aleatória.
META_VERIFY_TOKEN=
# META_APP_SECRET: App Settings → Básico → Chave secreta do app. Valida a
#   assinatura X-Hub-Signature-256 dos eventos. Se vazio, a validação é PULADA.
META_APP_SECRET=
# META_GRAPH_VERSION: versão da Graph API. Default v25.0 se vazio.
META_GRAPH_VERSION=v25.0
# Embedded Signup (cliente conecta a WABA dele sozinho). PÚBLICOS → exigem
# ARG+ENV no Dockerfile builder (já tem) + Build Args no EasyPanel, senão inlinam vazio.
# App ID: topo do painel do app. Config ID: WhatsApp → Embedded Signup (cria a config).
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=

# Web Push (VAPID) — notificações PWA mobile
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@seudominio.com
